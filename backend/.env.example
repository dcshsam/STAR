# Copy to .env and fill in. NEVER commit the real .env.
ENV=development
# Generate a strong key:  openssl rand -hex 32
SECRET_KEY=replace-with-openssl-rand-hex-32
ACCESS_TOKEN_EXPIRE_MINUTES=60
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
DATABASE_URL=sqlite:///./star.db
FIRST_ADMIN_USERNAME=admin
FIRST_ADMIN_EMAIL=admin@yourorg.com
FIRST_ADMIN_PASSWORD=ChangeMe!2026
# Optional: turn on Claude narrative via SAP Gen AI Hub (needs the SDK + AICORE_* vars)
USE_LLM_NARRATIVE=false
# AICORE_BASE_URL=...  (append /v2)
# AICORE_CLIENT_ID=...
# AICORE_CLIENT_SECRET=...
# AICORE_AUTH_URL=...
# AICORE_RESOURCE_GROUP=default
